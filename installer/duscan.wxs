<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="duscan"
    Language="1033"
    Version="$(var.Version)"
    Manufacturer="duscan"
    UpgradeCode="{505A9F38-7103-49B2-A4C4-A879C1C7156D}">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      InstallPrivileges="elevated"
      Platform="x64"
      Description="duscan CLI installer" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of duscan is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseFile)" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="duscan">
          <Component Id="DuscanExeComponent" Guid="{F44D483A-31D9-4F95-82BE-B6D2519E13B9}" Win64="yes">
            <File Id="DuscanExe" Source="$(var.ExeFile)" Name="duscan.exe" KeyPath="yes" />
          </Component>

          <Component Id="ReadmeComponent" Guid="{5DA947A6-CD39-4B1F-A3C8-1E0C95C58B0D}" Win64="yes">
            <File Id="ReadmeFile" Source="$(var.ReadmeFile)" Name="README.md" KeyPath="yes" />
          </Component>

          <Component Id="SystemPathComponent" Guid="{B6C1B53F-6B73-4C6B-9EC2-8DD75B5270D9}" Win64="yes">
            <RegistryValue
              Root="HKLM"
              Key="Software\duscan"
              Name="PathFeature"
              Type="integer"
              Value="1"
              KeyPath="yes" />
            <Environment
              Id="DuscanSystemPath"
              Name="PATH"
              Value="[INSTALLFOLDER]"
              Permanent="no"
              Part="last"
              Action="set"
              System="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="DefaultFeature" Title="duscan CLI" Level="1" Absent="disallow" AllowAdvertise="no">
      <ComponentRef Id="DuscanExeComponent" />
      <ComponentRef Id="ReadmeComponent" />
    </Feature>

    <Feature
      Id="PathFeature"
      Title="Add duscan to PATH (recommended)"
      Description="Adds the duscan install folder to the system PATH for all users."
      Level="1"
      AllowAdvertise="no">
      <ComponentRef Id="SystemPathComponent" />
    </Feature>

    <UIRef Id="WixUI_FeatureTree" />
  </Product>
</Wix>
