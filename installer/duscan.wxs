<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="duscan"
    Language="1033"
    Version="$(var.Version)"
    Manufacturer="duscan"
    UpgradeCode="{505A9F38-7103-49B2-A4C4-A879C1C7156D}">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perUser"
      InstallPrivileges="limited"
      Description="duscan CLI installer" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of duscan is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="LocalProgramsFolder" Name="Programs">
          <Directory Id="INSTALLFOLDER" Name="duscan">
            <Component Id="DuscanExeComponent" Guid="{F44D483A-31D9-4F95-82BE-B6D2519E13B9}">
              <File Id="DuscanExe" Source="$(var.ExeFile)" Name="duscan.exe" KeyPath="yes" />
              <Environment
                Id="DuscanUserPath"
                Name="PATH"
                Value="[INSTALLFOLDER]"
                Permanent="no"
                Part="last"
                Action="set"
                System="no" />
            </Component>

            <Component Id="ReadmeComponent" Guid="{5DA947A6-CD39-4B1F-A3C8-1E0C95C58B0D}">
              <File Id="ReadmeFile" Source="$(var.ReadmeFile)" Name="README.md" KeyPath="yes" />
            </Component>
          </Directory>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="DefaultFeature" Title="duscan" Level="1">
      <ComponentRef Id="DuscanExeComponent" />
      <ComponentRef Id="ReadmeComponent" />
    </Feature>
  </Product>
</Wix>
